# Copy to .env and adjust. Used by docker-compose and local runs.

# --- Postgres ---
POSTGRES_USER=events
POSTGRES_PASSWORD=events
POSTGRES_DB=events
# Async SQLAlchemy URL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://events:events@postgres:5432/events

# --- Redis (Streams + ZSET + FX cache) ---
REDIS_URL=redis://redis:6379/0
STREAM_KEY=transactions
CONSUMER_GROUP=processors
DLQ_STREAM_KEY=transactions:dead
RETRY_ZSET_KEY=transactions:retry

# --- FX rates ---
# Cache-aside in Redis under rate:{CUR}:USD with this TTL (seconds).
FX_RATE_TTL_SECONDS=300
FX_API_BASE_URL=https://api.exchangerate.host

# --- Retry / DLQ policy ---
MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=1
RETRY_MAX_DELAY_SECONDS=300

# --- Reads ---
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=50

# --- Metrics ---
METRICS_PORT=9100
